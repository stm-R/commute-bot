# Copy this file to .env and fill in your values
# Never commit .env to git

# Your Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-bot-token-here

# Your Discord application/client ID
DISCORD_CLIENT_ID=your-client-id-here

# The channel ID where daily prompts will be sent
# Right-click a channel in Discord → "Copy Channel ID" (needs Developer Mode on)
DISCORD_CHANNEL_ID=your-channel-id-here

# Optional: Guild (server) ID for instant slash command registration
# Leave empty to use global commands (takes ~1 hour to propagate)
# DISCORD_GUILD_ID=your-guild-id-here

# Optional: cron schedule (default: weekdays at 08:00)
# CRON_SCHEDULE=0 8 * * 1-5

# Optional: timezone (default: Europe/Amsterdam)
# TIMEZONE=Europe/Amsterdam

# Optional: regular day(s) off to skip daily prompts
# Comma-separated values: 0-6 (Sun=0) or names like mon,tue,wed,thu,fri,sat,sun
# Example: DAYS_OFF=wed
# Example: DAYS_OFF=wed,fri
# DAYS_OFF=
